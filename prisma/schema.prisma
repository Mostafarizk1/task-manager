generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String
  password  String
  role      String    @default("user")
  tasks     Task[]
  expenses  Expense[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Task {
  id                String   @id @default(cuid())
  taskName          String
  clientName        String
  deadline          DateTime
  totalPrice        Float
  currency          String   @default("USD")
  collaboratorName  String?
  collaboratorCut   Float    @default(0)
  netProfit         Float
  status            String   @default("To Do")
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([deadline])
  @@index([createdAt])
}

model Expense {
  id          String   @id @default(cuid())
  name        String
  amount      Float
  currency    String   @default("USD")
  category    String
  date        DateTime
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([date])
  @@index([category])
}
